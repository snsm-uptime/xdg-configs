# ── Credentials & secrets ─────────────────────────────────────────────────────
gh/hosts.yml               # OAuth tokens — never commit
ssh/known_hosts
ssh/id_*
ssh/*.pem
ssh/*.key

# ── nvim runtime ──────────────────────────────────────────────────────────────
nvim/config/lazy-lock.json  # submodule exception — lockfile regenerates on startup

# ── docker — only config.json is tracked, rest is runtime ───────────────────
docker/contexts/
docker/cli-plugins/
docker/.token

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
Thumbs.db
