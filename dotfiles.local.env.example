# Copy to dotfiles.local.env (gitignored) or run ./install.sh for interactive setup.
# All paths may use ${HOME}; no trailing slash on gitdir roots.

# Git includeIf + shell cd shortcuts: personal and uptime are ${DOTFILES_GITHUB_ROOT}/personal|uptime
DOTFILES_GITHUB_ROOT="${HOME}/github"

# SSH server shortcuts (alias.zsh + generated ssh/config.local)
DOTFILES_SSH_SERVER_IP="187.124.250.74"
DOTFILES_SSH_KEY_KVM="${HOME}/.ssh/uptime"

# Optional: hostname for EDITOR=nvim branch in .zshrc (empty = disabled)
DOTFILES_EDITOR_HOSTNAME=""
